{
  "comments": {
    "lineComment": "REM"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""]
  ],
  "wordPattern": "[A-Za-z][A-Za-z0-9!@#%&?]{0,7}\\$?",
  "indentationRules": {
    "increaseIndentPattern": "\\b(FOR|DO)\\b",
    "decreaseIndentPattern": "\\b(NEXT|RETURN)\\b"
  }
}
